APP_ENV=development
LLM_PROVIDER=mock
RAG_RETRIEVER=hybrid
RAG_TOP_K=5
RAG_MIN_SCORE=0.12
RAG_KEYWORD_MIN_SCORE=2.0
# dense 检索余弦相似度下限（bge-small-zh 基线 ~0.39，有效匹配 0.5-0.82）
RAG_DENSE_MIN_SCORE=0.45
RAG_QUERY_REWRITE=true
# 启用 LLM 查询改写（需 LLM_PROVIDER=deepseek 且配置 API Key）
RAG_QUERY_REWRITE_LLM=false
# 工作流引擎：procedural（默认）或 langgraph
LLM_WORKFLOW_ENGINE=procedural
# 存储后端：sqlite（默认）或 json
STORAGE_BACKEND=sqlite
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# 设为 deepseek-reasoner 启用深度推理（自由对话路径，有 CoT 思维链）
# FREE_CHAT_MODEL=deepseek-reasoner
QWEN_API_KEY=
# 飞书机器人 Webhook 地址（为空或 mock 时使用本地 mock 通知）
FEISHU_WEBHOOK_URL=mock
# 设为 true 时，启动后若无 trace 数据则自动生成 8 条演示数据
AUTO_SEED_DEMO_DATA=false
# 当前行业模板，默认 demo_ecommerce
SUPPORTPILOT_TEMPLATE=demo_ecommerce
# 自由对话模式（关闭后始终走 RAG 路径）
FREE_CHAT_ENABLED=true
# === OpenAI (LLM_PROVIDER=openai) ===
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# === 通义千问 (LLM_PROVIDER=qwen) ===
# QWEN_MODEL=qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
